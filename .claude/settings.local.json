{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Read(*)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Write(.codex/**)",
      "Write(.claude/**)",
      "Bash(pkill -f \"vite\")",
      "Bash(git rm *)",
      "Bash(npx tsc *)",
      "Bash(npx vite *)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(wrangler deploy:*)",
      "Write(.env*)"
    ]
  }
}
